{
  "name": "pdf-ocr-ts",
  "version": "1.0.35",
  "description": "Javascript-only library to perform OCR on scanned PDFs to turn them into searchable PDFs",
  "main": "./build/PdfOcr.js",
  "dependencies": {
    "canvas": "^3.2.1",
    "jimp": "^1.6.0",
    "pdf-lib": "^1.17.1",
    "pdf-ocr-ts": "file:",
    "pdfjs-dist": "4.7.76",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "tesseract.js": "^5.1.1",
    "ts-jest": "^29.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.26.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "canvas": "^3.2.1",
    "handlebars": "^4.7.9",
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.2",
    "test-exclude": "^8.0.0"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "test": "jest --coverage --detectOpenHandles --forceExit --transformIgnorePatterns \"node_modules/(?!pdfjs-dist)/\"",
    "test:watch": "jest --watch",
    "build": "rimraf ./build && tsc",
    "start": "npx ts-node ./src/ocrMyPdf.ts",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastianheide/pdf-ocr-ts.git"
  }
}
